@using Microsoft.AspNetCore.Identity
@inject SignInManager<User> SignInManager
@{
    string c = ViewContext.RouteData.Values["controller"].ToString();
    string a = ViewContext.RouteData.Values["action"].ToString();
}

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <form class="form-inline" href="/Account/ChosenLessons" >
                <a class="nav-link @(c == "Account" & a == "ChosenSessions" ? "active" : "")" href="/Account/ChosenSessions">Chosen Sessions</a>
        </form>
    </li>
    <li class="nav-item">
        <a  class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a>
        </li>
    <li class="nav-item">
        <form class="form-inline" href="/Account/Logout">
               <a class="nav-link" href="/Account/Logout">Logout</a>
        </form>
    </li>
        
        
}
else
{
    <li class="nav-item">
            <a class="nav-link @(c == "Account" & a == "Register" ? "active" : "")" href="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
            <a class="nav-link @(c == "Account" & a == "Login" ? "active" : "")" href="/Account/Login">Login</a>
    </li>
}
</ul>
