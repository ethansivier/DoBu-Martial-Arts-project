@model ForumModel

<div class= "container py-4" >
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Community Forum</h2><button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#createPostModal">
            <svg class="bi bi-plus-circle me-2" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"></path>
                <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path>
            </svg>Create Post
        </button>
    </div>
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="list-group shadow-sm">
                @foreach (ForumPost post in Model.Posts)
                {
                    <form asp-action="PostView" asp-controller="Forum" method="post">
                        <input type="hidden" name="postId" value="@post.PostId" />
                        <button class="list-group-item list-group-item-action py-3" type="submit">
                            <div class="d-flex w-100 justify-content-between">
                                <h5 class="fw-bold mb-1">@post.PostTitle</h5><small class="text-muted">@post.PostDate.ToString()</small>
                            </div>
                            <p class="text-secondary mb-1">
                                @(post.PostBody.Length >= 20 ? $"{post.PostBody.Substring(0, 20)}..." : post.PostBody)
                            </p>
                            <div class="d-flex align-items-center mt-2">
                                <small class="text-muted me-3">
                                    <svg class="bi bi-person me-1" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"></path>
                                    </svg>@post.Owner.UserName
                                </small><small class="text-muted">
                                    <svg class="bi bi-chat-dots me-1" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M5 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0m4 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0m3 1a1 1 0 1 0 0-2 1 1 0 0 0 0 2"></path>
                                        <path d="m2.165 15.803.02-.004c1.83-.363 2.948-.842 3.468-1.105A9 9 0 0 0 8 15c4.418 0 8-3.134 8-7s-3.582-7-8-7-8 3.134-8 7c0 1.76.743 3.37 1.97 4.6a10.4 10.4 0 0 1-.524 2.318l-.003.011a11 11 0 0 1-.244.637c-.079.186.074.394.273.362a22 22 0 0 0 .693-.125m.8-3.108a1 1 0 0 0-.287-.801C1.618 10.83 1 9.468 1 8c0-3.192 3.004-6 7-6s7 2.808 7 6-3.004 6-7 6a8 8 0 0 1-2.088-.272 1 1 0 0 0-.711.074c-.387.196-1.24.57-2.634.893a11 11 0 0 0 .398-2"></path>
                                    </svg>@post.Comments.Count.ToString() replies
                                </small>
                            </div>
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" role="dialog" tabindex="-1" id="createPostModal" aria-labelledby="createPostModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createPostModalLabel">Create New Post</h5><button class="btn-close" aria-label="Close" data-bs-dismiss="modal" type="button"></button>
            </div>
            <form asp-action="CreatePost" asp-controller="Forum">
                <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label" for="postTitle">Title</label>
                            <input class="form-control" type="text" asp-for="@Model.PostTitle" id="postTitle" placeholder="What's on your mind?">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" for="postContent">Content</label>
                            <textarea class="form-control" asp-for="@Model.PostBody" id="postContent" placeholder="Share more details..." rows="4"></textarea>
                         </div>
                </div>

                <div class="modal-footer">
                    <button class="btn btn-secondary" data-bs-dismiss="modal" type="button">Cancel</button>
                    <button class="btn btn-primary" type="submit">Post to Forum</button>
                </div>

            </form>

        </div>
    </div>
</div>
