@model EditMembershipModel

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h5 class="mb-4 card-title">Plan Details</h5>
        <form>
            <input type="hidden" asp-for="@Model.ChosenMembershipID" value="@Model.ChosenMembershipID" />
            <input type="hidden" asp-for="@Model.update" value="True" />
            <div class="row mb-3 g-3">
                <div class="col-md-6">
                    <label class="form-label">Plan Name</label>
                    <input class="form-control" type="text" asp-for="@Model.newName"  placeholder="e.g Basic">
                </div>
                <div class="col-md-6">
                    <label class="form-label">Price ($)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input class="form-control" type="number" asp-for="@Model.newPrice"  placeholder="0.00" step="0.01">
                    </div>
                </div>
            </div>
            <div class="row mb-3 g-3">
                <div class="col-md-6">
                    <label class="form-label" asp-for="@Model.newMartialArts">Martial Arts Classes Count</label>
                    <input class="form-control" asp-for="@Model.newMartialArts"  type="number" id="martialArtsCount" placeholder="Number of classes included">
                </div>
                <div class="col-md-6">
                    <label class="form-label" asp-for="@Model.newSessions">General Sessions Count</label>
                    <input class="form-control" asp-for="@Model.newSessions" type="number" id="sessionsCount" placeholder="Number of sessions included">
                </div>
            </div>
            <div class="mt-4 mb-4">
                <div class="form-check form-switch">
                    <input type="checkbox" class="form-check-input" id="isKidsPlan" asp-for="@Model.newIsKids">
                    <label class="form-check-label" for="isKidsPlan" asp-for="@Model.newIsKids">This is for Kids</label>
                    <div class="form-text"><span>Enable this if the plan is intended for children.</span></div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 pt-3 border-top"><button class="btn btn-outline-secondary" type="reset">Discard Changes</button><button class="btn btn-primary px-4" type="submit">Update Plan</button></div>
        </form>
    </div>
</div>