@model TimetableModel

<html data-bs-theme="light" lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>dobu martial arts</title>
    <link rel="stylesheet" href="assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="assets/css/Features-Cards-icons.css">
    <link rel="stylesheet" href="assets/css/Pricing-Centered-badges.css">
</head>

<body>
    <section class="text-white py-4 py-xl-5">
        <div class="container">
            <div class="border rounded border-0 d-flex flex-column justify-content-center align-items-center p-4 py-5" style="height: 500px;background-image: url(../assets/img/photo-1542937307-2d46ff7444a1.jpg);">
                <div class="row">
                    <div class="col-md-10 col-xl-8 text-center d-flex d-sm-flex d-md-flex justify-content-center align-items-center justify-content-md-start align-items-md-center justify-content-xl-center mx-auto">
                        <div style="filter: blur(0px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);">
                            <h1 class="text-uppercase fw-bold mb-3" style="color: var(--bs-light);text-shadow: 0px 0px 20px var(--bs-black);opacity: 1;filter: blur(0px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);">Timetable</h1>
                        </div>
                    </div>
                </div>
                <p style="font-weight: bold;text-align: center;text-shadow: 0px 0px 20px rgb(0,0,0);transform: perspective(2500px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);">Here are our current available lessons.<br>Select from the dropdown to choose a day</p>
            </div>
        </div>
    </section>

    <div class="container py-4 py-xl-5">
        <div class="row" style="margin: 0px;">
            <div class="col">
                <form asp-action="Timetable" asp-controller="Home" method="get">
                    <select class="form-select" onchange="this.form.submit()" asp-for="@Model.SelectedDayId" class="text-uppercase form-select" style="background: rgb(33,37,41);color: rgb(255,255,255);font-weight: bold;">
                        @foreach (var day in Model.Days)
                        {
                            <option value="@day.DayID">@day.Name</option>
                        }
                    </select>
                </form>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="text-uppercase text-center">Details</th>
                        <th class="text-uppercase text-center">Class</th>
                        <th class="text-uppercase text-center">Kids Class</th>
                        <th class="text-uppercase text-center">Private Class</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Day.Sessions)
                    {

                        if (s.Class.Name != "")
                        {
                            <tr>
                                <td class="text-center py-3">
                                    <div class="fw-bold fs-5">@s.Day.Name</div>
                                    <div class="text-muted mb-2">
                                        @s.TimeFormatted()
                                    </div>
                                    <form asp-action="Book" asp-controller="Home" method="post">
                                        <input type="hidden" name="sessionid" value="@s.SessionId" />
                                        <input type="hidden" name="dayid" value="@s.DayID" />
                                        <button class="btn btn-primary btn-sm" type="submit">Book now</button>
                                    </form>

                                </td>
                                <td class="text-center py-3"><div class="fw-bold fs-5 text-primary">@s.Class.Name</div></td>
                                <td class="text-center py-3">
                                    <div class="badge bg-@(s.Class.IsKids ? "success" : "secondary") rounded-pill">
                                        @(s.Class.IsKids ? "Yes" : "No")
                                    </div>
                                </td>
                                <td class="text-center py-3">
                                    <div class="badge bg-@(s.Class.IsPrivate ? "success" : "secondary") rounded-pill">
                                        @(s.Class.IsPrivate ? "Yes" : "No")
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
            
    </div>
    <script src="assets/bootstrap/js/bootstrap.min.js"></script>
</body>

</html>