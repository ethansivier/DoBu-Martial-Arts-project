@model PostViewModel
@{
     ForumPost post = Model.Post;
}

<div class="container py-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <nav class="mb-4" aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/Forum.html"><span>Forum</span></a></li>
                    <li class="breadcrumb-item active" aria-current="page"><span>Post Details</span></li>
                </ol>
            </nav>
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="text-white bg-primary rounded-circle d-flex justify-content-center align-items-center me-3" style="width:48px;height:48px;">
                            <svg class="bi bi-person fs-4" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"></path>
                            </svg>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0">@post.Owner.UserName</h6><small class="text-muted">@post.PostDate</small>
                        </div>
                    </div>
                    <h2 class="fw-bold mb-3">@post.PostTitle</h2>
                    <p class="fs-5 text-secondary" id="post-body">@post.PostBody</p>
                    <button class="btn btn-link p-0 mb-3" id="read-more-btn" style="display:none;">Read More</button>
                    <div class="d-flex mt-4 pt-3 border-top">
                        <button class="btn btn-link text-decoration-none p-0 me-4 text-muted">
                            <svg class="bi bi-hand-thumbs-up me-1" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8.864.046C7.908-.193 7.02.53 6.956 1.466c-.072 1.051-.23 2.016-.428 2.59-.125.36-.479 1.013-1.04 1.639-.557.623-1.282 1.178-2.131 1.41C2.685 7.288 2 7.87 2 8.72v4.001c0 .845.682 1.464 1.448 1.545 1.07.114 1.564.415 2.068.723l.048.03c.272.165.578.348.97.484.397.136.861.217 1.466.217h3.5c.937 0 1.599-.477 1.934-1.064a1.86 1.86 0 0 0 .254-.912c0-.152-.023-.312-.077-.464.201-.263.38-.578.488-.901.11-.33.172-.762.004-1.149.069-.13.12-.269.159-.403.077-.27.113-.568.113-.857 0-.288-.036-.585-.113-.856a2 2 0 0 0-.138-.362 1.9 1.9 0 0 0 .234-1.734c-.206-.592-.682-1.1-1.2-1.272-.847-.282-1.803-.276-2.516-.211a10 10 0 0 0-.443.05 9.4 9.4 0 0 0-.062-4.509A1.38 1.38 0 0 0 9.125.111zM11.5 14.721H8c-.51 0-.863-.069-1.14-.164-.281-.097-.506-.228-.776-.393l-.04-.024c-.555-.339-1.198-.731-2.49-.868-.333-.036-.554-.29-.554-.55V8.72c0-.254.226-.543.62-.65 1.095-.3 1.977-.996 2.614-1.708.635-.71 1.064-1.475 1.238-1.978.243-.7.407-1.768.482-2.85.025-.362.36-.594.667-.518l.262.066c.16.04.258.143.288.255a8.34 8.34 0 0 1-.145 4.725.5.5 0 0 0 .595.644l.003-.001.014-.003.058-.014a9 9 0 0 1 1.036-.157c.663-.06 1.457-.054 2.11.164.175.058.45.3.57.65.107.308.087.67-.266 1.022l-.353.353.353.354c.043.043.105.141.154.315.048.167.075.37.075.581 0 .212-.027.414-.075.582-.05.174-.111.272-.154.315l-.353.353.353.354c.047.047.109.177.005.488a2.2 2.2 0 0 1-.505.805l-.353.353.353.354c.006.005.041.05.041.17a.9.9 0 0 1-.121.416c-.165.288-.503.56-1.066.56z"></path>
                            </svg> Like
                        </button><button class="btn btn-link text-decoration-none p-0 text-muted" href="comment">
                            <svg class="bi bi-reply me-1" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M6.598 5.013a.144.144 0 0 1 .202.134V6.3a.5.5 0 0 0 .5.5c.667 0 2.013.005 3.3.822.984.624 1.99 1.76 2.595 3.876-1.02-.983-2.185-1.516-3.205-1.799a8.7 8.7 0 0 0-1.921-.306 7 7 0 0 0-.798.008h-.013l-.005.001h-.001L7.3 9.9l-.05-.498a.5.5 0 0 0-.45.498v1.153c0 .108-.11.176-.202.134L2.614 8.254l-.042-.028a.147.147 0 0 1 0-.252l.042-.028zM7.8 10.386q.103 0 .223.006c.434.02 1.034.086 1.7.271 1.326.368 2.896 1.202 3.94 3.08a.5.5 0 0 0 .933-.305c-.464-3.71-1.886-5.662-3.46-6.66-1.245-.79-2.527-.942-3.336-.971v-.66a1.144 1.144 0 0 0-1.767-.96l-3.994 2.94a1.147 1.147 0 0 0 0 1.946l3.994 2.94a1.144 1.144 0 0 0 1.767-.96z"></path>
                            </svg> Reply
                        </button>
                    </div>
                </div>
            </div>
            <h5 class="fw-bold mb-3">Comments @post.Comments.Count.ToString()</h5>
            @foreach (ForumComment comment in post.Comments)
            {
                <div class="card border-0 shadow-sm mb-3" data-comment-id="@comment.Id" data-post-id="@post.PostId">
                    <div class="card-body p-4">
                        <div class="position-absolute top-0 end-0 me-2 mt-2 dropdown">
                            <button class="btn btn-link p-0 text-muted" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <svg class="bi bi-three-dots-vertical fs-5" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"></path>
                                </svg>
                            </button>
                            <form asp-action="CommentDelete" asp-controller="Forum">
                                <input type="hidden" name="commentId" value="@comment.Id" />
                            </form>
                            <form asp-action="CommentEdit" asp-controller="Forum">
                                <input type="hidden" name="commentId" value="@comment.Id" />
                            </form>
                            <ul class="shadow-sm dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item edit-comment-btn" href="#">
                                        <svg class="bi bi-pencil me-2" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"></path>
                                        </svg>Edit
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item text-danger" href="#">
                                        <svg class="bi bi-trash me-2" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"></path>
                                            <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"></path>
                                        </svg>Delete
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="d-flex align-items-start">
                            <div class="text-white bg-secondary rounded-circle d-flex flex-shrink-0 justify-content-center align-items-center me-3" style="width:40px;height:40px;">
                                <svg class="bi bi-person" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"></path>
                                </svg>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <h6 class="fw-bold mb-0">@comment.User.UserName</h6><small class="text-muted">@comment.Time.ToString()</small>
                                </div>
                                <div class="comment-content">
                                    <p class="text-secondary mb-0 comment-text">@comment.Comment</p>
                                </div>
                                <div class="d-none mt-2 edit-comment-actions"><button class="btn btn-primary btn-sm me-2 save-edit-btn">Save</button><button class="btn btn-light btn-sm cancel-edit-btn">Cancel</button></div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="fw-bold mb-3" id="comment">Add a comment</h6>
                    <form asp-action="PostComment" asp-controller="Forum">
                        <input type="hidden" name="postId" value="@Model.Post.PostId" />
                        <div class="mb-3"><textarea class="form-control" asp-for="@Model.Comment" placeholder="Write your reply..." rows="3"></textarea></div>
                        <div class="text-end"><button class="btn btn-primary px-4" type="submit">Post Comment</button></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="~/js/post-view.js"></script>
