@model User

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <title>dobu martial arts</title>
    <link rel="stylesheet" href="assets/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="assets/css/Features-Cards-icons.css">
    <link rel="stylesheet" href="assets/css/Pricing-Centered-badges.css">
</head>

<body>
    <div class="border rounded border-0 d-flex flex-column justify-content-center align-items-center p-4 py-5" style="height: 500px;background: url(../assets/img/photo-1599677100568-a367e56ca161.jpg) center / auto no-repeat;">
        <div class="row">
            <div class="col-md-10 col-xl-8 text-center d-flex d-sm-flex d-md-flex justify-content-center align-items-center justify-content-md-start align-items-md-center justify-content-xl-center mx-auto">
                <div style="filter: blur(0px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);">
                    <h1 class="text-uppercase fw-bold mb-3" style="color: var(--bs-light);text-shadow: 0px 0px 20px var(--bs-black);opacity: 1;filter: blur(0px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);">Chosen lessons</h1>
                </div>
            </div>
        </div>
        <p style="text-align: center;text-shadow: 0px 0px 12px rgb(0,0,0);transform: perspective(0px);backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);-webkit-backdrop-filter: opacity(1) blur(0px) contrast(100%) grayscale(0%);color: var(--bs-gray-100);font-weight: bold;"><br><span style="font-weight: normal !important;">If you change your mind on a lesson, click the "remove" button.</span><br><br><br></p>
    </div>
    <div class="container py-4 py-xl-5">
        <div class="row mb-5">
            <div class="col-md-8 col-xl-6 text-center mx-auto">
                <h2>Chosen lessons</h2>
                <p>If you change your mind on a lesson, click the "remove" button.</p>
            </div>
        </div>
        <div class="row gy-4 row-cols-1 row-cols-md-2 row-cols-xl-3">
            <div class="col col-md-12 col-lg-12 col-xl-12">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="text-align: center;">Details</th>
                                <th style="text-align: center;">Class</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var s in Model.Sessions)
                            {
                                <tr>
                                    <td style="text-align: center;">@s.Day.Name<br>@s.TimeFormatted()<br>
                                    <form asp-action="RemoveSession" asp-controller="Account" method="post">
                                        <input type="hidden" name="sessionid" value="@s.SessionId" />
                                        <button class="btn btn-primary btn-sm" type="submit">Remove</button>
                                    </form>
                                    <td style="text-align: center;">@s.Class.Name</td>
                                </tr> 
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <script src="assets/bootstrap/js/bootstrap.min.js"></script>
</body>

</html>